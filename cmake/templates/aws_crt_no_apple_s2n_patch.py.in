import pathlib

# aws-crt-cpp builds s2n-tls AND aws-lc on macOS ("both Secure Transport and
# s2n are built; the TLS backend is selected at runtime"). Envy forces
# USE_S2N=OFF on Apple and uses Secure Transport, so neither s2n nor its aws-lc
# dependency is ever linked -- but they still compile, costing ~1.7 MB of build
# work for nothing. Narrow the guard so the whole s2n/aws-lc block is skipped on
# Apple; Linux (UNIX AND NOT APPLE) is unaffected.

awscrt_cmakelists = pathlib.Path(r"@AWSCRT_CMAKELISTS@")
text = awscrt_cmakelists.read_text()

marker = "# envy: skip s2n/aws-lc on Apple"

old_line = (
    "    if(UNIX AND NOT BYO_CRYPTO AND "
    "(NOT APPLE OR CMAKE_SYSTEM_NAME STREQUAL \"Darwin\"))"
)
new_line = (
    "    if(UNIX AND NOT BYO_CRYPTO AND NOT APPLE) "
    "# envy: skip s2n/aws-lc on Apple, use Secure Transport"
)

if old_line not in text:
    if marker in text:
        raise SystemExit(0)
    raise RuntimeError("aws-crt-cpp s2n/aws-lc guard line not found")

text = text.replace(old_line, new_line, 1)
awscrt_cmakelists.write_text(text)
